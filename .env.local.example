# Copy this file to .env.local and fill in your own Supabase project values.
# Find these under Supabase Dashboard → Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# NEVER put the service_role/secret key here or in any NEXT_PUBLIC_ variable.
# It only belongs in server-only environments (e.g. a seed script run locally,
# or Vercel's server-side environment variables for admin-only API routes).
#
# Required locally for app/api/orders/route.ts (order placement) — find it
# under Supabase Dashboard → Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Transactional email (order confirmation/shipped/cancelled). Get a key at
# https://resend.com — server-only, never a NEXT_PUBLIC_ variable.
RESEND_API_KEY=your-resend-api-key

# Discord log mirroring — each is a per-channel webhook URL (Channel Settings
# → Integrations → Webhooks → New Webhook). All 3 optional: if unset,
# sendToDiscord() silently no-ops for that channel. Server-only, never a
# NEXT_PUBLIC_ variable.
DISCORD_WEBHOOK_NOTIFICATIONS=your-notifications-channel-webhook-url
DISCORD_WEBHOOK_AUDIT_LOG=your-audit-log-channel-webhook-url
DISCORD_WEBHOOK_ERRORS=your-errors-channel-webhook-url

# Anti-bot protection on signup — Cloudflare Turnstile (not reCAPTCHA).
# Two keys come as a pair from https://dash.cloudflare.com → Turnstile →
# Add site:
#   1. Site key  → goes here, NEXT_PUBLIC_TURNSTILE_SITE_KEY (this app's
#      frontend loads Cloudflare's widget script with it).
#   2. Secret key → does NOT go in this app's env at all. Paste it into
#      Supabase Dashboard → Authentication → Attack Protection → enable
#      "Captcha protection" → paste the secret key there. Supabase's own
#      servers verify the token against that secret when signUp() is
#      called — this app's Next.js server never sees or checks it.
# Optional: leave NEXT_PUBLIC_TURNSTILE_SITE_KEY unset and the CaptchaWidget
# on /account renders nothing at all (no error, no broken build) — signUp()
# simply omits captchaToken, which Supabase ignores when the project's own
# captcha protection isn't turned on. Safe default for local dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Phone verification (SMS OTP on /account/security) — INTENTIONALLY
# DISABLED FOR NOW. Keep this "false" until a production SMS provider
# (Twilio/Vonage/etc) has actually been contracted and wired into
# lib/sms.ts's sendSms() — flipping it to "true" today just logs the OTP to
# the server console instead of texting it, which is fine for local
# testing but not for real users. The security page shows a plain "Phone
# verification is coming soon" notice instead of an OTP form while this is
# false, and registration/login/checkout are completely unaffected either
# way — phone verification has never been required for any of those.
SMS_VERIFICATION_ENABLED=false
