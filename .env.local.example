# Copy this file to .env.local and fill in your own Supabase project values.
# Find these under Supabase Dashboard → Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# NEVER put the service_role/secret key here or in any NEXT_PUBLIC_ variable.
# It only belongs in server-only environments (e.g. a seed script run locally,
# or Vercel's server-side environment variables for admin-only API routes).
#
# Required locally for app/api/orders/route.ts (order placement) — find it
# under Supabase Dashboard → Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Transactional email (order confirmation/shipped/cancelled). Get a key at
# https://resend.com — server-only, never a NEXT_PUBLIC_ variable.
RESEND_API_KEY=your-resend-api-key

# Discord log mirroring — each is a per-channel webhook URL (Channel Settings
# → Integrations → Webhooks → New Webhook). All 3 optional: if unset,
# sendToDiscord() silently no-ops for that channel. Server-only, never a
# NEXT_PUBLIC_ variable.
DISCORD_WEBHOOK_NOTIFICATIONS=your-notifications-channel-webhook-url
DISCORD_WEBHOOK_AUDIT_LOG=your-audit-log-channel-webhook-url
DISCORD_WEBHOOK_ERRORS=your-errors-channel-webhook-url

# Anti-bot protection on signup (Cloudflare Turnstile). Optional: leave unset
# and the CaptchaWidget on /account renders nothing, and signUp() simply
# omits captchaToken — only enable this once captcha protection is also
# turned on for the project in Supabase Dashboard → Authentication →
# Attack Protection (using the matching Turnstile secret key there).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Phone verification (SMS OTP on /account/security). Optional: leave unset
# and phone verification stays visibly "unverified" without blocking any
# account action. Requires a real SMS provider account (Twilio/Vonage/etc)
# — see lib/sms.ts for the provider integration point.
SMS_VERIFICATION_ENABLED=false
